{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/api\\.php(.*)",
      "dest": "/api/api.php$1"
    },
    {
      "src": "/admin\\.php(.*)",
      "dest": "/api/admin.php$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
